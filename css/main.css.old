:root {
    /* Colors */
    --color-primary-yellow: #FFE500;
    --color-accent-pink: #FF2D78;
    --color-accent-blue: #0066FF;
    --color-light-blue: #E0ECFF;
    
    --color-bg-warm: #FAFAF5;
    --color-bg-white: #FFFFFF;
    
    --color-text-black: #0A0A0A;
    --color-text-dark: #333333;
    --color-text-medium: #444444;
    --color-text-light: #666666;
    
    /* Typography */
    --font-heading: 'Bebas Neue', sans-serif;
    --font-body: 'Bricolage Grotesque', sans-serif;
    --font-ui: 'Roboto', sans-serif;
    
    /* Base spacing from design (often 48px baseline) */
    --spacing-sm: 8px;
    --spacing-md: 24px;
    --spacing-lg: 48px;
    --spacing-xl: 96px;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    cursor: none; /* Hide default cursor because of custom cursor */
}

html, body {
    background-color: var(--color-bg-warm);
    color: var(--color-text-medium);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
    width: 100vw;
    margin: 0;
    padding: 0;
}

body {
    padding-top: 86px;
}

a {
    text-decoration: none;
    color: inherit;
    cursor: none;
}

li {
    list-style: none;
}

/* Synergy Cursor */
#cursor-dot, #cursor-aura {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 10000;
    mix-blend-mode: difference;
    border-radius: 50%;
    transform: translate(-50%, -50%);
}

#cursor-dot {
    width: 8px;
    height: 8px;
    background-color: #ffffff;
    transition: width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
}

#cursor-aura {
    width: 40px;
    height: 40px;
    border: 1.5px solid rgba(255, 255, 255, 0.8);
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                height 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                background-color 0.4s ease,
                border-color 0.4s ease;
}

/* Cursor States */
body.cursor-hover #cursor-dot {
    width: 0;
    height: 0;
    opacity: 0;
}

body.cursor-hover #cursor-aura {
    width: 80px;
    height: 80px;
    background-color: rgba(255, 255, 255, 0.15);
    border-color: transparent;
}

body.cursor-click #cursor-aura {
    transform: translate(-50%, -50%) scale(0.85);
}

/* Hide system cursor globally */
*, html, body, a, button, .peek-card, .menu-btn, .view-link {
    cursor: none !important;
}

/* Nav */
#nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 48px;
    background-color: var(--color-bg-warm);
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
}

.nav-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary-yellow);
    width: 59px;
    height: 46px;
    font-family: var(--font-heading);
    font-size: 31px; /* Approximation based on height */
    color: var(--color-text-black);
    line-height: 1;
}

.nav-links {
    display: flex;
    gap: 8px;
}

.nav-links a {
    padding: 8px 16px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-black);
}

/* Footer */
footer {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background-color: var(--color-bg-warm);
    height: 86px;
    align-items: center;
    padding: 0 48px;
    border-top: 1px solid #E5E5E5;
}

.footer-col {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: center;
}

.footer-col-label {
    font-size: 14px;
    font-family: var(--font-body);
    font-weight: 700;
    color: var(--color-text-black);
}

.footer-col p:not(.footer-col-label), .footer-col-link {
    font-size: 16px;
    color: var(--color-text-medium);
    font-weight: 500;
}

/* Universal UI Components */
.pill {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 100px;
    color: var(--color-bg-warm);
    display: inline-block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.pill:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}
.pill.blue { background-color: var(--color-accent-blue); }
.pill.pink { background-color: var(--color-accent-pink); }
.pill.orange { background-color: #FF6B00; }
.pill.blue-light { background-color: var(--color-light-blue); color: var(--color-text-black); }
.pill.red { background-color: #FD0505; }
